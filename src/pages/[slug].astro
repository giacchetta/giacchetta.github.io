---
import { getCollection } from 'astro:content';
import SlugPage from '../components/SlugPage.astro';

export async function getStaticPaths() {
  const credentials = await getCollection('credentials');
  const collaborations = await getCollection('collaborations');
  const certifications = await getCollection('certifications');

  const allPages = [...credentials, ...collaborations, ...certifications];

  // English pages only (no locale suffix in id like "github-actionses-ar")
  return allPages
    .filter((page) => !/(es-ar|es-uy)$/.test(page.id))
    .map((page) => ({
      params: { slug: page.id },
      props: { page },
    }));
}

const { page } = Astro.props;
---
<SlugPage page={page} />

---
import Layout from '../../layouts/Layout.astro';
import Collaboration from '../../components/Collaboration.astro';
import { useTranslations } from '../../i18n/utils';

const locale = Astro.currentLocale ?? 'es-uy';
const t = useTranslations(locale);
---
<Layout title={`${t('experience.pageTitle')} | ${t('bio.name')}`}>
  <main class="container layout mt-3 mb-5">
    <h1 class="display-5 fw-bold mb-4">{t('experience.pageTitle')}</h1>
    <Collaboration/>
  </main>
</Layout>

---
import Favicon from '../assets/img/favicon.png';
import Footer from '../components/Footer.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { useTranslations, getLocaleForDate } from '../i18n/utils';
import '../styles/bootstrap.min.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);

const langMap: Record<string, string> = { 'en': 'en', 'es-ar': 'es-AR', 'es-uy': 'es-UY' };
const htmlLang = langMap[locale] ?? 'en';

const path = Astro.url.pathname;
const cleanPath = path.replace(/^\/(es-ar|es-uy)/, '') || '/';
---

<!doctype html>
<html lang={htmlLang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={t('meta.description')} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/png" href={Favicon.src} />
		<meta name="generator" content={Astro.generator} />
		<link rel="alternate" hreflang="en" href={cleanPath} />
		<link rel="alternate" hreflang="es-AR" href={`/es-ar${cleanPath}`} />
		<link rel="alternate" hreflang="es-UY" href={`/es-uy${cleanPath}`} />
		<link rel="alternate" hreflang="x-default" href={cleanPath} />
		<title>{title}</title>
	</head>
	<body class="bg-light">
		<LanguageSwitcher />
		<slot />
		<Footer />
	</body>
</html>
<script>
	import 'bootstrap/dist/js/bootstrap.js';
</script>
<style is:global>
	body {
		overflow-x: clip;
	}

	@media (min-width: 992px) {
	.layout {
		max-width: 75%;
		}
	}

	@media (min-width: 1400px) {
	.layout {
		max-width: 65%;
		}
	}
</style>

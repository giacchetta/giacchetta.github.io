---
import { Image } from 'astro:assets';
import { getAllPages, getFeaturedPagesByCategory, getNonFeaturedPagesByCategory } from '../utils/content.js';

const allPages = await getAllPages();
const featuredCollaborationsPages = getFeaturedPagesByCategory(allPages, 'collaborations');
const collaborationPages = getNonFeaturedPagesByCategory(allPages, 'collaborations')
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<h2>Collaborations</h2>

{featuredCollaborationsPages.length > 0 && (
  <div id="detailed-case-studies" class="mb-4">
    <h4 class="text-primary">Detailed Case Studies</h4>
    <div class="row">
      {featuredCollaborationsPages.map((page) => (
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title">
                <a href={`/${page.slug}/`} class="text-decoration-none">
                  {page.data.title}
                </a>
              </h5>
              {page.data.description && (
                <p class="card-text text-muted small">{page.data.description}</p>
              )}
              <a href={`/${page.slug}/`} class="btn btn-sm btn-outline-success">
                Read Case Study →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
)}

<div class="row">
  {collaborationPages.map((page) => (
    <div class="col-12 col-sm-6 col-lg-4 mb-3">
      <div class="card shadow-sm h-100">
        {page.data.logo && (
          <div class="d-flex justify-content-center align-items-center p-3" style="height: 100px;">
            <a href={`/${page.slug}/`}>
              <Image
                src={page.data.logo}
                alt={page.data.title}
                style="max-height: 80px; max-width: 100%; object-fit: contain;"
              />
            </a>
          </div>
        )}
        <div class="card-body d-flex flex-column p-3">
          <h6 class="card-title mb-1">
            <a href={`/${page.slug}/`} class="text-decoration-none">
              {page.data.title}
            </a>
          </h6>
          {page.data.role && (
            <span class="badge bg-primary-subtle text-primary mb-1">{page.data.role}</span>
          )}
          {page.data.period && (
            <small class="text-muted">{page.data.period}</small>
          )}
          {page.data.summary && (
            <p class="card-text small mt-2 mb-2" style="text-align: justify;">
              {page.data.summary.length > 250
                ? page.data.summary.substring(0, 250) + '...'
                : page.data.summary}
            </p>
          )}
          <a href={`/${page.slug}/`} class="btn btn-sm btn-outline-primary mt-auto">
            Read more →
          </a>
        </div>
      </div>
    </div>
  ))}
</div>

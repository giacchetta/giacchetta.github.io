---
import { Image } from 'astro:assets';
import { getAllPages, getFeaturedPagesByCategory, getNonFeaturedPagesByCategory } from '../utils/content.js';

const allPages = await getAllPages();
const featuredCollaborationsPages = getFeaturedPagesByCategory(allPages, 'collaborations');
const collaborationPages = getNonFeaturedPagesByCategory(allPages, 'collaborations')
  .sort((a, b) => (a.data.order ?? 999) - (b.data.order ?? 999));
---
<h2>Collaborations</h2>

{featuredCollaborationsPages.length > 0 && (
  <div id="detailed-case-studies" class="mb-4">
    <h4 class="text-primary">Detailed Case Studies</h4>
    <div class="row">
      {featuredCollaborationsPages.map((page) => (
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title">
                <a href={`/${page.slug}/`} class="text-decoration-none">
                  {page.data.title}
                </a>
              </h5>
              {page.data.description && (
                <p class="card-text text-muted small">{page.data.description}</p>
              )}
              <a href={`/${page.slug}/`} class="btn btn-sm btn-outline-success">
                Read Case Study →
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
)}

{collaborationPages.map((page) => (
  <div id={page.slug} class="container mt-2">
    <div class="row">
      <div class="col-0 col-md-3 col-lg-3 col-xl-3">
        <a href={`/${page.slug}/`}>
          {page.data.logo && (
            <Image
              class="img-thumbnail"
              src={page.data.logo}
              alt={page.data.title}
            />
          )}
        </a>
      </div>
      <div class="col-12 col-md-9 col-lg-9 col-xl-8">
        <ul class="list-unstyled">
          {page.data.role && <li><b>{page.data.role}</b></li>}
          {page.data.period && <li>{page.data.period}</li>}
          {page.data.location && <li>{page.data.location}</li>}
        </ul>
      </div>
    </div>
    {page.data.summary && (
      <p style="text-align: justify;">{page.data.summary}</p>
    )}
  </div>
))}

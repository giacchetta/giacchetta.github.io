---
import { getAllPages, getFeaturedPagesByCategory, cleanSlug } from '../utils/content.js';
import { useTranslations, localePath } from '../i18n/utils';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);

// Load locale-specific credentials JSON if available
let credentialsData;
if (locale !== 'en') {
  try {
    const mod = await import(`../data/credentials.${locale}.json`);
    credentialsData = mod.default;
  } catch {
    credentialsData = (await import('../data/credentials.json')).default;
  }
} else {
  credentialsData = (await import('../data/credentials.json')).default;
}

const credentialSections = Object.entries(credentialsData).map(([key, value]) => {
  return { title: key, data: value };
});

const allPages = await getAllPages(locale);
const featuredCredentialsPages = getFeaturedPagesByCategory(allPages, 'credentials');
---
<h2>{t('credentials.heading')}</h2>

{featuredCredentialsPages.length > 0 && (
  <div class="mb-4">
    <h4 class="text-primary">{t('credentials.detailed')}</h4>
    <div class="row">
      {featuredCredentialsPages.map((page) => (
        <div class="col-md-6 col-lg-4 mb-3">
          <div class="card h-100">
            <div class="card-body">
              <h5 class="card-title">
                <a href={localePath(`/${cleanSlug(page)}/`, locale)} class="text-decoration-none">
                  {page.data.title}
                </a>
              </h5>
              {page.data.description && (
                <p class="card-text text-muted small">{page.data.description}</p>
              )}
              <a href={localePath(`/${cleanSlug(page)}/`, locale)} class="btn btn-sm btn-outline-primary">
                {t('credentials.learnMore')} &rarr;
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
)}

{credentialSections.map((section) => (
  <div class="mb-4">
    <h3>{section.title}</h3>
    <div class="row">
      {section.data &&
        section.data.map((entry) => (
          <div class="col-12 col-sm-6 col-lg-4 mb-3">
            <div class="card shadow-sm h-100">
              <div class="card-body d-flex flex-column p-3">
                <div class="mb-2">
                  <span class="badge bg-primary-subtle text-primary">{entry.product}</span>
                </div>
                <h6 class="card-title mb-2">
                  {entry.namelnk === '#' ? entry.name : <a href={entry.namelnk} class="text-decoration-none">{entry.name}</a>}
                </h6>
                <div class="mt-auto">
                  {entry.typelnk === '#'
                    ? <span class="badge bg-secondary-subtle text-secondary">{entry.type}</span>
                    : <a href={entry.typelnk} class="badge bg-secondary-subtle text-secondary text-decoration-none">{entry.type}</a>
                  }
                </div>
              </div>
            </div>
          </div>
        ))}
    </div>
  </div>
))}

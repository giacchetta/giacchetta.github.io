---
import { Image } from 'astro:assets';
import Contact from './Contact.astro';
import emailIcon from '../assets/img/email.png';
import githubIcon from '../assets/img/github-icon.png';
import gianetIcon from '../assets/img/gianet.png';
import linkedinIcon from '../assets/img/linkedin-icon.png';
import { useTranslations } from '../i18n/utils';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
const date = new Date();
---
<footer class="text-center py-1">
	<small class="text-muted">{t('footer.lastUpdate')} {date.toDateString()}</small>
</footer>
<nav class="navbar fixed-bottom bg-light border-top py-1 px-3">
	<div class="d-flex align-items-center gap-3 ms-auto">
		<a href="https://github.com/giacchetta" aria-label="GitHub">
			<Image src={githubIcon} alt="GitHub" height={32} class="rounded-circle" />
		</a>
		<a href="https://gianet.us/giacchetta" aria-label="GiaNet">
			<Image src={gianetIcon} alt="GiaNet" height={32} class="rounded-circle" />
		</a>
		<a href="https://www.linkedin.com/in/giacchetta/" aria-label="LinkedIn">
			<Image src={linkedinIcon} alt="LinkedIn" height={32} class="rounded-circle" />
		</a>
		<button type="button" class="btn p-0 border-0" data-bs-toggle="modal" data-bs-target="#contactModal">
			<Image src={emailIcon} alt="Email" height={36} class="rounded-circle" />
		</button>
	</div>
</nav>
<!-- Modal rendered outside the fixed navbar to avoid stacking context issues -->
<Contact />

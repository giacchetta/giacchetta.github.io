---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import Contact from './Contact.astro';
import { getCollection } from 'astro:content';
import { useTranslations, localePath, getLocaleForDate } from '../i18n/utils';
import { cleanSlug, filterByLocale } from '../utils/content.js';

interface Props {
  page: any;
}

const { page } = Astro.props;
const { Content } = await page.render();
const isCollaboration = page.collection === 'collaborations';
const isCompanyCollaboration = isCollaboration && page.data.type === 'company';
const isArticleCollaboration = isCollaboration && page.data.type === 'article';

const locale = Astro.currentLocale ?? 'en';
const t = useTranslations(locale);
const dateLocale = getLocaleForDate(locale);

let companyEntry: any = null;
let linkedArticles: any[] = [];

if (isCollaboration) {
  const allCollaborations = await getCollection('collaborations');
  const localeCollabs = filterByLocale(allCollaborations, locale);

  if (isArticleCollaboration && page.data.company) {
    companyEntry = localeCollabs.find(
      (e: any) => e.data.type === 'company' && cleanSlug(e) === page.data.company
    ) ?? null;
  }

  if (isCompanyCollaboration) {
    const currentSlug = cleanSlug(page);
    linkedArticles = localeCollabs.filter(
      (e: any) => e.data.type === 'article' && e.data.company === currentSlug
    );
  }
}
---

<Layout title={`${page.data.title} | Luciano Giacchetta`}>
  <main>
    <div class="container layout mt-4">
      <div class="row">
        <div class="col-12">
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
              <li class="breadcrumb-item">
                <a href={localePath('/', locale)} class="text-decoration-none">{t('nav.home')}</a>
              </li>
              <li class="breadcrumb-item active" aria-current="page">
                {page.data.title}
              </li>
            </ol>
          </nav>
        </div>
      </div>

      <article class="row">
        <div class="col-12">
          {isCompanyCollaboration ? (
            <header class="mb-4">
              <h1 class="display-5 fw-bold text-primary mb-0">{page.data.title}</h1>
              <ul class="list-unstyled mb-3 mt-2">
                {page.data.role && <li><b>{page.data.role}</b></li>}
                {page.data.period && <li>{page.data.period}</li>}
                {page.data.location && <li>{page.data.location}</li>}
              </ul>
              {page.data.summary && (
                <p style="text-align: justify;">{page.data.summary}</p>
              )}
            </header>
          ) : isCollaboration && (page.data.role || page.data.logo) ? (
            <header class="mb-4">
              <div class="row align-items-center mb-3">
                {page.data.logo && (
                  <div class="col-auto">
                    <Image
                      class="img-thumbnail"
                      src={page.data.logo}
                      alt={page.data.title}
                      style="max-height: 80px; width: auto;"
                    />
                  </div>
                )}
                <div class="col">
                  <h1 class="display-5 fw-bold text-primary mb-0">{page.data.title}</h1>
                </div>
              </div>
              <ul class="list-unstyled mb-3">
                {page.data.role && <li><b>{page.data.role}</b></li>}
                {page.data.period && <li>{page.data.period}</li>}
                {page.data.location && <li>{page.data.location}</li>}
              </ul>
              {page.data.summary && (
                <p style="text-align: justify;">{page.data.summary}</p>
              )}
            </header>
          ) : (
            <header class="mb-4">
              <h1 class="display-5 fw-bold text-primary">{page.data.title}</h1>
              {page.data.description && (
                <p class="lead text-muted">{page.data.description}</p>
              )}
              <div class="meta-info mb-3">
                {page.data.category && (
                  <span class="badge bg-secondary me-2">{page.data.category}</span>
                )}
                <div class="text-muted small mt-2">
                  {page.data.publishDate && (
                    <span class="me-3">
                      {t('date.published')} {new Date(page.data.publishDate).toLocaleDateString(dateLocale, {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </span>
                  )}
                  {page.data.updateDate && page.data.updateDate !== page.data.publishDate && (
                    <span>
                      {t('date.updated')} {new Date(page.data.updateDate).toLocaleDateString(dateLocale, {
                        year: 'numeric',
                        month: 'long',
                        day: 'numeric'
                      })}
                    </span>
                  )}
                </div>
              </div>
              {companyEntry && (
                <div class="mt-2">
                  <span class="text-muted small me-1">{t('collaborations.partOfWorkAt')}</span>
                  <a
                    href={localePath(`/${cleanSlug(companyEntry)}/`, locale)}
                    class="badge bg-primary-subtle text-primary text-decoration-none"
                  >
                    {companyEntry.data.logo && (
                      <Image
                        src={companyEntry.data.logo}
                        alt={companyEntry.data.title}
                        style="height: 16px; width: auto; vertical-align: middle;"
                        class="me-1"
                      />
                    )}
                    {companyEntry.data.title}
                  </a>
                </div>
              )}
            </header>
          )}

          <div class="content">
            <Content />
          </div>

          {linkedArticles.length > 0 && (
            <div class="mt-5">
              <h2 class="h4 fw-semibold text-primary mb-3">{t('collaborations.relatedArticles')}</h2>
              <div class="list-group">
                {linkedArticles.map((article: any) => (
                  <a
                    href={localePath(`/${cleanSlug(article)}/`, locale)}
                    class="list-group-item list-group-item-action"
                  >
                    <div class="fw-semibold">{article.data.title}</div>
                    {article.data.description && (
                      <div class="text-muted small">{article.data.description}</div>
                    )}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      </article>

      <Contact />
    </div>
  </main>
</Layout>

<style>
  .content {
    line-height: 1.7;
  }

  .content :global(h2) {
    color: var(--bs-primary);
    margin-top: 2rem;
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .content :global(h3) {
    color: var(--bs-dark);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    font-weight: 500;
  }

  .content :global(p) {
    text-align: justify;
  }

  .content :global(ul),
  .content :global(ol) {
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-bottom: 0.5rem;
  }

  .content :global(blockquote) {
    border-left: 4px solid var(--bs-primary);
    padding-left: 1rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--bs-secondary);
  }

  .content :global(code) {
    background-color: var(--bs-light);
    padding: 0.2rem 0.4rem;
    border-radius: 0.25rem;
  }

  .content :global(pre) {
    background-color: var(--bs-dark);
    color: var(--bs-light);
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin: 1rem 0;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
    color: inherit;
  }
</style>

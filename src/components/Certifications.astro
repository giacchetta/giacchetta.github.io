---
import { getAllPages } from '../utils/content.js';

const allPages = await getAllPages();
const allCertificationsPages = allPages.certifications || [];
---
<h2>Certifications</h2>

{allCertificationsPages.length > 0 && (
  <div class="row">
    {allCertificationsPages.map((page) => (
      <div class="col-12 col-sm-6 col-lg-4 mb-3">
        <div class="card h-100 shadow-sm">
          <div class="card-body d-flex flex-column p-4">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h5 class="card-title mb-0">
                <a href={`/${page.slug}/`} class="text-decoration-none">
                  {page.data.title}
                </a>
              </h5>
              <span class={`badge rounded-pill ${page.data.status === 'Active' ? 'bg-success' : 'bg-warning'}`}>
                {page.data.status || 'Unknown'}
              </span>
            </div>
            <div class="d-flex flex-wrap gap-1 mb-2">
              {page.data.provider && (
                <span class="badge bg-secondary-subtle text-secondary">
                  {page.data.provider}
                </span>
              )}
              {page.data.certificationLevel && (
                <span class="badge bg-primary-subtle text-primary rounded-pill">
                  {page.data.certificationLevel}
                </span>
              )}
            </div>
            {page.data.description && (
              <p class="card-text text-muted small">{page.data.description}</p>
            )}
            {page.data.credentialUrl && page.data.credentialUrl !== '#' && (
              <div class="mt-auto pt-2">
                <a href={page.data.credentialUrl} target="_blank" class="btn btn-sm btn-outline-primary">
                  View Credential →
                </a>
              </div>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
)}
